from pyspark.sql import functions as F

def clean_data(df):
    """
    Əsas təmizləmə funksiyası:
    - Dublikatları silir
    - String sütunlardakı kənar boşluqları (trim) silir
    - Mənfi ədədləri təmizləyir
    """
    id_cols = [c for c in df.columns if c.lower().endswith('_id') or c.lower().endswith('_code')]
    if id_cols:
        df = df.dropDuplicates(id_cols)
    else:
        df = df.dropDuplicates()

    for col_name, dtype in df.dtypes:
        if dtype == "string":
            df = df.withColumn(col_name, F.trim(F.col(col_name)))
            
    for col_name, dtype in df.dtypes:
        if dtype in ["int", "double", "long", "float"]:
            df = df.filter(F.col(col_name) >= 0)

    return df

def normalize_columns(df):
    """
    Sütun adlarını kiçik hərflərə çevirir
    """
    for col_name in df.columns:
        df = df.withColumnRenamed(col_name, col_name.lower())
    return df

def remove_nulls(df, subset_cols=None):
    """
    Null dəyərləri təmizləyir
    """
    if subset_cols:
        return df.dropna(subset=subset_cols)
    return df.dropna()
