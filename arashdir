SELECT transaction_id, order_id, amount, payment_method, transaction_status, processed_at
FROM gulnara.finance;

import logging
from typing import Optional

from airflow.providers.amazon.aws.hooks.s3 import S3Hook

from spark.main_etl import clean_data
from spark.spark_utils import (
    get_postgres_jdbc_config,
    get_spark_session,
)


MINIO_CONN_ID = "minio_conn"
BUCKET_NAME = "data"

TARGET_SCHEMA = "gulnara"
TARGET_TABLE = "finance"

PROCESSED_PREFIX = "download_history/processed/finance"


def move_object_to_processed(
    source_key: str,
    processed_prefix: str,
) -> str:
    """
    Copy a successfully processed MinIO object to the processed folder,
    then delete the original object.
    """

    s3_hook = S3Hook(aws_conn_id=MINIO_CONN_ID)

    file_name = source_key.rsplit("/", 1)[-1]
    destination_key = f"{processed_prefix}/{file_name}"

    s3_hook.copy_object(
        source_bucket_key=source_key,
        dest_bucket_key=destination_key,
        source_bucket_name=BUCKET_NAME,
        dest_bucket_name=BUCKET_NAME,
    )

    s3_hook.delete_objects(
        bucket=BUCKET_NAME,
        keys=[source_key],
    )

    logging.info(
        "Moved MinIO object from %s to %s.",
        source_key,
        destination_key,
    )

    return destination_key


def run_finance_etl(
    source_key: Optional[str] = None,
    **context,
) -> dict:
    """
    Read one Finance CSV file from MinIO, clean it with Spark,
    append the result to PostgreSQL, and move the source file
    to the processed folder.
    """

    if not source_key:
        task_instance = context["ti"]
        source_key = task_instance.xcom_pull(
            task_ids="generate_finance_csv"
        )

    if not source_key:
        raise ValueError(
            "Finance source key was not received from XCom."
        )

    spark = None

    try:
        spark = get_spark_session(
            app_name="Gulnara_Finance_ETL"
        )

        source_path = f"s3a://{BUCKET_NAME}/{source_key}"

        logging.info(
            "Reading Finance source file: %s",
            source_path,
        )

        bronze_df = (
            spark.read
            .option("header", "true")
            .option("inferSchema", "true")
            .option("delimiter", ",")
            .csv(source_path)
        )

        source_record_count = bronze_df.count()

        if source_record_count == 0:
            raise ValueError(
                f"Finance source file is empty: {source_key}"
            )

        silver_df = clean_data(bronze_df)

        cleaned_record_count = silver_df.count()

        jdbc_url, jdbc_properties = get_postgres_jdbc_config()

        target_table = f"{TARGET_SCHEMA}.{TARGET_TABLE}"

        (
            silver_df.write
            .mode("append")
            .jdbc(
                url=jdbc_url,
                table=target_table,
                properties=jdbc_properties,
            )
        )

        processed_key = move_object_to_processed(
            source_key=source_key,
            processed_prefix=PROCESSED_PREFIX,
        )

        result = {
            "source_key": source_key,
            "processed_key": processed_key,
            "source_record_count": source_record_count,
            "cleaned_record_count": cleaned_record_count,
            "target_table": target_table,
            "write_mode": "append",
        }

        logging.info(
            "Finance ETL completed successfully: %s",
            result,
        )

        return result

    except Exception:
        logging.exception(
            "Finance ETL failed for source file: %s",
            source_key,
        )
        raise

    finally:
        if spark is not None:
            spark.stop()
            logging.info(
                "Finance SparkSession stopped."
            )
