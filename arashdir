def run_etl_process(**kwargs):

    # 1. Airflow özü MinIO-ya qoşulur (S3Hook vasitəsilə)

    s3_hook = S3Hook(aws_conn_id="minio_conn")

    bucket_name = "data"

    s3_prefix = "download_history/orders_history/"

    # Bucket-dəki faylları tapırıq

    keys = s3_hook.list_keys(bucket_name=bucket_name, prefix=s3_prefix)

    if not keys:

        print("❌ MinIO-da oxunacaq fayl tapılmadı!")

        return

    # Məsələn, ən son yüklənən JSON faylını seçirik:

    json_keys = [k for k in keys if k.endswith('.json')]

    target_key = json_keys[-1] # Ən sonuncu fayl

    print(f"Airflow MinIO-dan faylı endirir: {target_key}")

    # Faylı Airflow konteynerinin lokalına müvəqqəti yükləyirik

    local_file_path = s3_hook.download_file(

        key=target_key, 

        bucket_name=bucket_name, 

        local_path="/tmp"

    )

    # 2. Spark Session utilitdən çağırılır

    spark = get_spark_session(app_name="Gulnara_Cleaning_Pipeline")

    # 3. Spark lokal faylı xətasız və rahat şəkildə oxuyur

    print(f"Spark faylı oxuyur: {local_file_path}")

    bronze_df = spark.read.option("multiline", "true").json(local_file_path)

    # 4. Təmizləmə prosesləri

    silver_df = clean_data(bronze_df)

    silver_df = remove_nulls(silver_df)

    silver_df = normalize_columns(silver_df)
    print(f"TEMIZ DATA>>>>>>>>>>")
    silver_df.show(5, truncate=False)
    silver_df.printSchema()
    

    # İş bitdikdən sonra təmizlik

    spark.stop()
