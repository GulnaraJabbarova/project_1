import logging
from typing import Dict, Any

from spark.spark_utils import (
    get_postgres_jdbc_config,
    get_spark_session,
)
from pyspark.sql import functions as F

# Konfiqurasiya parametrləri
SILVER_SCHEMA = "gulnara"
SILVER_TABLE = "finance"

GOLD_SCHEMA = "gulnara"
GOLD_TABLE = "gold_finance_daily_summary"


def transform_silver_to_gold(silver_df):
    """
    Sütunlar: transaction_id, order_id, amount, payment_method, transaction_status, processed_at
    """
    df_with_date = silver_df.withColumn(
        "transaction_date",
        F.to_date(F.col("processed_at"))
    )

    gold_df = (
        df_with_date
        .groupBy(
            "transaction_date",
            "payment_method"
        )
        .agg(
            F.count("transaction_id").alias("total_transactions"),
            F.countDistinct("order_id").alias("total_orders"),
            F.coalesce(F.sum("amount"), F.lit(0)).alias("total_amount"),
            F.coalesce(F.avg("amount"), F.lit(0)).alias("avg_transaction_amount"),
            
            F.coalesce(
                F.sum(
                    F.when(
                        F.upper(F.col("transaction_status")).isin("SUCCESS", "COMPLETED", "APPROVED"), 
                        F.col("amount")
                    ).otherwise(0)
                ), 
                F.lit(0)
            ).alias("successful_amount"),
            
            F.count(
                F.when(
                    F.upper(F.col("transaction_status")).isin("SUCCESS", "COMPLETED", "APPROVED"), 
                    F.col("transaction_id")
                )
            ).alias("successful_transactions_count"),
            
            F.count(
                F.when(
                    F.upper(F.col("transaction_status")).isin("FAILED", "DECLINED", "ERROR"), 
                    F.col("transaction_id")
                )
            ).alias("failed_transactions_count"),

            F.current_timestamp().alias("updated_at")
        )
    )
    
    return gold_df


# Airflow bu funksiyanı çağırır (Arqumentlər istəyə bağlı (Optional) edilməlidir)
def run_finance_silver_to_gold_etl(**context) -> Dict[str, Any]:
    """
    Silver (gulnara.finance) cədvəlindən məlumatları oxuyur,
    aqreqasiya edir və Gold cədvəlinə yazır.
    """
    spark = None

    try:
        spark = get_spark_session(
            app_name="Gulnara_Finance_To_Gold"
        )

        jdbc_url, jdbc_properties = get_postgres_jdbc_config()
        
        silver_target = f"{SILVER_SCHEMA}.{SILVER_TABLE}"
        gold_target = f"{GOLD_SCHEMA}.{GOLD_TABLE}"

        logging.info("Silver cədvəlindən məlumatlar oxunur: %s", silver_target)

        # silver_df-i funksiyanın daxilində Postgres-dən oxuyuruq
        silver_df = (
            spark.read
            .jdbc(
                url=jdbc_url,
                table=silver_target,
                properties=jdbc_properties
            )
        )

        silver_count = silver_df.count()

        if silver_count == 0:
            logging.warning("Silver cədvəli boşdur. Gold ETL prosesi dayandırılır.")
            return {"status": "skipped", "reason": "Silver table is empty"}

        gold_df = transform_silver_to_gold(silver_df)
        gold_count = gold_df.count()

        logging.info("Gold məlumatları yazılır: %s", gold_target)

        (
            gold_df.write
            .mode("overwrite")
            .option("truncate", "true")
            .jdbc(
                url=jdbc_url,
                table=gold_target,
                properties=jdbc_properties,
            )
        )

        result = {
            "silver_source_table": silver_target,
            "gold_target_table": gold_target,
            "silver_record_count": silver_count,
            "gold_record_count": gold_count,
            "write_mode": "overwrite",
        }

        logging.info("Finance Gold ETL uğurla başa çatdı: %s", result)
        return result

    except Exception:
        logging.exception("Finance To Gold ETL zamanı xəta baş verdi.")
        raise

    finally:
        if spark is not None:
            spark.stop()
            logging.info("Finance To Gold SparkSession dayandırıldı.")
