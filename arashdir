import logging

import pendulum

from airflow import DAG
from airflow.hooks.base import BaseHook
from airflow.operators.empty import EmptyOperator
from airflow.operators.python import PythonOperator

from generators.customer_location_generator import (
    generate_customer_location_in_sql,
)
from generators.finance_generator import generate_finance_csv
from generators.orders_generator import generate_orders_json

from spark.customer_location_etl import (
    run_customer_location_etl,
)
from spark.finance_etl import run_finance_etl
from spark.orders_etl import run_orders_etl
from spark.orders_silver_to_gold import run_orders_silver_to_gold_etl


BAKU_TZ = pendulum.timezone("Asia/Baku")

MINIO_CONN_ID = "minio_conn"
MSSQL_CONN_ID = "ms_sql_conn"
POSTGRES_CONN_ID = "postgres_conn"


def check_airflow_connections() -> dict:
    """
    Check whether all required Airflow connections exist.

    For AWS/MinIO connections, the endpoint may be stored in Extra,
    so Host is not required.
    """

    required_connections = [
        MINIO_CONN_ID,
        MSSQL_CONN_ID,
        POSTGRES_CONN_ID,
    ]

    validated_connections = []

    for connection_id in required_connections:
        connection = BaseHook.get_connection(connection_id)

        logging.info(
            "Connection found: id=%s, type=%s",
            connection_id,
            connection.conn_type,
        )

        if connection_id == MINIO_CONN_ID:
            endpoint_url = connection.extra_dejson.get(
                "endpoint_url"
            )

            if not endpoint_url:
                raise ValueError(
                    f"'endpoint_url' is missing in Extra for "
                    f"connection: {connection_id}"
                )

            logging.info(
                "MinIO endpoint validated: %s",
                endpoint_url,
            )

        validated_connections.append(connection_id)

    result = {
        "status": "success",
        "validated_connections": validated_connections,
    }

    logging.info(
        "All required Airflow connections are valid: %s",
        result,
    )

    return result


default_args = {
    "owner": "Gulnara",
    "depends_on_past": False,
    "retries": 1,
}


with DAG(
    dag_id="gulnara_data_pipeline",
    description=(
        "Generate dirty Orders, Finance and Customer Location data, "
        "clean it with Spark and load it into PostgreSQL."
    ),
    default_args=default_args,
    start_date=pendulum.datetime(
        2026,
        7,
        10,
        tz=BAKU_TZ,
    ),
    schedule="0 10 * * *",
    catchup=False,
    max_active_runs=1,
    tags=[
        "gulnara",
        "spark",
        "minio",
        "mssql",
        "postgresql",
    ],
) as dag:

    start = EmptyOperator(
        task_id="start",
    )

    check_connections = PythonOperator(
        task_id="check_connections",
        python_callable=check_airflow_connections,
    )

    generate_orders = PythonOperator(
        task_id="generate_orders_json",
        python_callable=generate_orders_json,
    )

    generate_finance = PythonOperator(
        task_id="generate_finance_csv",
        python_callable=generate_finance_csv,
    )

    generate_customer_location = PythonOperator(
        task_id="generate_customer_location_in_sql",
        python_callable=generate_customer_location_in_sql,
    )

    process_orders = PythonOperator(
        task_id="process_orders",
        python_callable=run_orders_etl,
        op_kwargs={
            "source_key": (
                "{{ ti.xcom_pull("
                "task_ids='generate_orders_json'"
                ") }}"
            ),
        },
    )

    process_orders_gold = PythonOperator(
    task_id="process_orders_gold",
    python_callable=run_orders_silver_to_gold_etl,
)

    process_finance = PythonOperator(
        task_id="process_finance",
        python_callable=run_finance_etl,
        op_kwargs={
            "source_key": (
                "{{ ti.xcom_pull("
                "task_ids='generate_finance_csv'"
                ") }}"
            ),
        },
    )

    process_customer_location = PythonOperator(
        task_id="process_customer_location",
        python_callable=run_customer_location_etl,
    )

    end = EmptyOperator(
        task_id="end",
    )

    start >> check_connections

    check_connections >> [
        generate_orders,
        generate_finance,
        generate_customer_location,
    ]

    generate_orders >> process_orders >> process_orders_gold
    generate_finance >> process_finance

    (
        generate_customer_location
        >> process_customer_location
    )

    [
        process_orders_gold,
        process_finance,
        process_customer_location,
    ] >> end


